# System
.DS_Store
Thumbs.db

# Python
*.pyc
__pycache__/
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Data (never commit raw data)
data/raw/*
data/processed/*
data/reference/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/reference/.gitkeep

# Models (large binary files)
models/*.pt
models/*.pth
models/*.onnx
models/*.h5
!models/.gitkeep
# Some loaders (ultralytics) drop weights into CWD on first call
*.pt
*.pth
*.onnx

# Secrets
.env
.env.*
!.env.example

# MLOps
wandb/
mlruns/
*.log

# Testing / Coverage
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
coverage.xml

data/players/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars.local
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
