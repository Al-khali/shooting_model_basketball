# Copy this file to .env and fill in your values
# cp .env.example .env

# --- VLM API Keys (at least one required for feedback generation) ---
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Inference settings ---
# Pose model: yolov11-pose | vitpose | mediapipe
POSE_MODEL=yolov11-pose
# Device: cpu | cuda | mps (Apple Silicon)
DEVICE=cpu

# --- VLM provider ---
# VLM provider: gemini | openai | qwen
VLM_PROVIDER=gemini
VLM_MODEL=gemini-1.5-flash

# --- App ---
DEBUG=false
LOG_LEVEL=INFO
API_PORT=8000
