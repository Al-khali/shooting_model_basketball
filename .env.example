# ──────────────────────────────────────────────────────────────────────────────
# .env.example — environment variables template
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# .env MUST NOT be committed (it's in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=AI Shoot
DEBUG=false
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8080

# Auth — leave empty to disable (dev mode)
# Format: JSON array of strings
# API_KEYS=["your-local-key-here"]

# CORS — comma-separated origins or JSON array
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# VLM API Keys (at least one required for feedback generation)
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# VLM provider: gemini | openai | qwen
VLM_PROVIDER=gemini
VLM_MODEL=gemini-1.5-flash

# Inference
# Pose model: yolov11-pose | vitpose | mediapipe
POSE_MODEL=yolov11-pose
# Device: cpu | cuda | mps (Apple Silicon)
DEVICE=cpu
