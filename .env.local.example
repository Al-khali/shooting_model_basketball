# ──────────────────────────────────────────────────────────────────────────────
# .env.local — local development environment variables
# Copy this to .env.local and fill in real values.
# This file MUST NOT be committed (it's in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=AI Shoot (local)
DEBUG=false
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8080

# Auth — leave empty to disable (dev mode)
# Format: JSON array of strings
# API_KEYS=["your-local-key-here"]

# CORS — comma-separated origins or JSON array
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# VLM — required for coaching feedback
# GEMINI_API_KEY=your-gemini-api-key-here

# Inference device: cpu | cuda | mps
DEVICE=cpu
